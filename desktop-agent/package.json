{
  "name": "ocne-desktop-agent",
  "version": "0.1.0",
  "private": true,
  "author": "OCNE",
  "description": "OCNE Desktop Agent for connecting the OCNE website to a user's computer.",
  "main": "src/main.cjs",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "icons": "node scripts/generate-icons.cjs",
    "package:win": "electron-builder --win nsis",
    "package:mac": "electron-builder --mac dmg"
  },
  "dependencies": {
    "electron-updater": "^6.6.2"
  },
  "devDependencies": {
    "electron": "^38.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.ocne.desktop-agent",
    "productName": "OCNE Desktop Agent",
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "beshers",
        "repo": "ONCE",
        "releaseType": "release"
      }
    ],
    "files": [
      "src/**/*",
      "ui/**/*",
      "build/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": "nsis",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OCNE Desktop Agent",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeader": "build/installer-header.bmp",
      "installerSidebar": "build/installer-sidebar.bmp",
      "license": "build/license.txt",
      "runAfterFinish": true,
      "artifactName": "OCNE-Desktop-Agent-Setup-${version}.${ext}"
    },
    "mac": {
      "icon": "build/icon.png",
      "target": "dmg",
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    }
  }
}
